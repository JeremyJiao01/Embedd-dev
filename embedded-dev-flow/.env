# ╔══════════════════════════════════════════════════════════════╗
# ║  embedded-dev-flow 环境变量配置                              ║
# ║  标 [必填] 的必须配置，其余有合理默认值                        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── 1. crewAI 使用的 LLM（Agent 推理用）─────────────────────────
#
#    crewAI 默认模型: gpt-4.1-mini
#    模型名格式示例:
#      OpenAI:    gpt-4o / gpt-4.1-mini
#      Anthropic: anthropic/claude-sonnet-4-20250514
#      DeepSeek:  deepseek/deepseek-chat（需设 BASE_URL）
#      Ollama:    ollama/llama3（本地免 key）
#
#    只需配置你选择的那一组，不用全填。

# --- 方案 A: OpenAI / OpenAI 兼容接口（默认）---
OPENAI_API_KEY=sk-xxx                          # [必填] OpenAI API key
# OPENAI_MODEL_NAME=gpt-4o                     # 可选，默认 gpt-4.1-mini
# OPENAI_API_BASE=https://api.openai.com/v1    # 可选，用代理时改这里

# --- 方案 B: Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-xxx                 # [必填] Anthropic API key
# MODEL=anthropic/claude-sonnet-4-20250514        # 指定模型

# --- 方案 C: 本地 Ollama（无需 key）---
# MODEL=ollama/llama3
# OPENAI_API_BASE=http://localhost:11434

# --- 方案 D: Azure OpenAI ---
# AZURE_API_KEY=xxx
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-06-01
# MODEL=azure/your-deployment-name


# ── 2. CodeGraphWiki LLM（Cypher 生成 / Wiki 生成用）────────────
#
#    CodeGraphWiki 有独立的 LLM 配置，优先级: LLM_API_KEY > OPENAI_API_KEY > MOONSHOT_API_KEY
#    如果和 crewAI 用同一个 LLM，只需上面配了 OPENAI_API_KEY 即可，这里不用重复配。
#    如果想用不同的模型（比如便宜的模型做 Cypher 生成），取消下面的注释：

# LLM_API_KEY=sk-xxx                           # 可选，CodeGraphWiki 专用 LLM key
# LLM_BASE_URL=https://api.openai.com/v1       # 可选，默认 OpenAI
# LLM_MODEL=gpt-4o                             # 可选，默认 gpt-4o


# ── 3. 向量嵌入（语义搜索用）────────────────────────────────────
#
#    code_search 工具依赖向量嵌入，优先级:
#      DASHSCOPE_API_KEY → Qwen3 嵌入（推荐，阿里云免费额度大）
#      EMBEDDING_API_KEY / OPENAI_API_KEY → OpenAI text-embedding-3-small
#      都不配 → DummyEmbedder（返回零向量，语义搜索不可用）

DASHSCOPE_API_KEY=sk-xxx                       # [必填*] 阿里云 DashScope key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1  # 可选

# 或者用 OpenAI 嵌入（二选一即可）：
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL=text-embedding-3-small


# ── 4. 代码仓配置 ──────────────────────────────────────────────

INVERTER_REPO_PATH=/path/to/your/inverter/repo # [必填] 逆变器代码仓绝对路径
CGB_DB_PATH=./.code-graph/graph.db             # 可选，图数据库存储路径


# ── 5. 可选配置 ────────────────────────────────────────────────

# crewAI 遥测（默认开启，可关闭）
# OTEL_SDK_DISABLED=true

# crewAI 存储目录
# CREWAI_STORAGE_DIR=./.crewai

# CodeGraphWiki 工作空间
# CGB_WORKSPACE=~/.code-graph-builder
